    "test": "npm run test --workspaces --if-present",
    "migrate": "node-pg-migrate"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "node-pg-migrate": "^7.6.1",
    "@types/node": "^20.14.15"
  }
}
