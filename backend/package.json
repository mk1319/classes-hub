{
  "name": "backend",
  "private": true,
  "workspaces": [
    "packages/*",
    "auth",
    "authorizer",
    "tenants",
    "users",
    "courses",
    "tests",
    "timetable",
    "notifications",
    "uploads",
    "resources",
    "syllabus"
